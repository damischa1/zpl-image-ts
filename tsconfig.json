{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2024",
        "lib": ["ES2024", "DOM"],
        "types": ["node"],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "verbatimModuleSyntax": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "rootDir": "./src",
        "outDir": "./dist"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "test"]
}
